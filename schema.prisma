generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id              Int      @id @default(autoincrement())
  first_name      String
  last_name       String
  email           String   @unique
  phone_number    String?  @unique
  district        String?
  city            String?
  address         String?
  profile_img_url String?
  hashed_password String
  role            Role     @default(CUSTOMER)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model OTP {
  id         Int      @id @default(autoincrement())
  email      String
  otp_code   String
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  image_url  String?
  products   Product[]
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
}

model Product {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  image_url   String?
  category_id Int
  category         Category           @relation(fields: [category_id], references: [id])
  variations       ProductVariation[]
  party_menu_items PartyMenuItem[]
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
}

model ProductVariation {
  id         Int     @id @default(autoincrement())
  name       String
  price      Float
  product_id Int
  product    Product @relation(fields: [product_id], references: [id])
  updated_at DateTime @updatedAt
}

model PartyMenu {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  image_url   String?
  price       Float
  category    String?
  items       PartyMenuItem[]
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
}

model PartyMenuItem {
  id            Int       @id @default(autoincrement())
  party_menu_id Int
  party_menu    PartyMenu @relation(fields: [party_menu_id], references: [id], onDelete: Cascade)
  product_id    Int
  product       Product   @relation(fields: [product_id], references: [id])
  created_at    DateTime  @default(now())

  @@index([party_menu_id])
  @@index([product_id])
}
